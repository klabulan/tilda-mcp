{
  "name": "@theyahia/tilda-mcp",
  "version": "1.1.1-fork.0",
  "description": "Fork of @theyahia/tilda-mcp adding write-tools (create_page, add_block, import_zeroblock, edit_block, publish) via Playwright editor automation. Read tools preserved from upstream.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "tilda-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "playwright": "^1.60.0",
    "undici": "^8.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "mcpName": "io.github.theYahia/tilda-mcp",
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "claude",
    "ai",
    "russian-api",
    "tilda",
    "website-builder",
    "cms",
    "api",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/theYahia/tilda-mcp.git"
  },
  "homepage": "https://github.com/theYahia/tilda-mcp#readme",
  "author": "theYahia (https://github.com/theYahia)"
}
